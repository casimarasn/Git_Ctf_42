#!/bin/bash

# Definición de colores
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# Archivo oculto para guardar el progreso del jugador
STATE_FILE=".ctf_state"

if [ ! -f "$STATE_FILE" ]; then
    STATE="0_START"
else
    STATE=$(cat "$STATE_FILE")
fi

# ==========================================
# FUNCIONES DE PREPARACIÓN DE NIVELES (START)
# ==========================================

setup_lvl1() {
    clear
    echo -e "${BLUE}====================================================${NC}"
    echo -e "${YELLOW}               <GIT/> CTF - 42 MÁLAGA                ${NC}"
    echo -e "${BLUE}====================================================\n${NC}"
    echo -e "¡Bienvenido! Has clonado el repositorio con éxito.\n"
    
    echo -e "${YELLOW}>> NIVEL 1: UNIVERSOS PARALELOS <<${NC}\n"
    echo -e "Misión:"
    echo -e "1. Crea una rama llamada ${GREEN}fix-norminette${NC} y sitúate en ella."
    echo -e "2. Añade un comentario al final de ${GREEN}utils.c${NC} que diga: ${YELLOW}// fix norm${NC}"
    echo -e "3. Registra este cambio en el historial de tu nueva rama."
    echo -e "4. NO fusiones (merge) la rama todavía.\n"
    
    echo -e "Cuando creas que lo tienes, vuelve a ejecutar: ${BLUE}./git-gud${NC}"
    echo "1_PENDING" > "$STATE_FILE"
}

setup_lvl2() {
    clear
    echo -e "${YELLOW}>> NIVEL 2: EL CHOQUE DE TRENES (MERGE CONFLICT) <<${NC}\n"
    echo "El Sensei está preparando el escenario en la sombra..."
    
    # Magia oscura para crear el conflicto
    cat <<EOF > main.c
#include <unistd.h>
int main(void) {
    // TODO: iniciar variables
    return (0);
}
EOF
    git add main.c
    git commit -m "Añadida estructura inicial" --quiet

    git branch compañero-rama
    git checkout compañero-rama --quiet
    cat <<EOF > main.c
#include <unistd.h>
int main(void) {
    // Variables inicializadas por tu compañero
    return (0);
}
EOF
    git add main.c
    git commit -m "Compañero inicializa variables" --quiet

    git checkout main --quiet
    cat <<EOF > main.c
#include <unistd.h>
int main(void) {
    // Variables inicializadas por mi
    return (0);
}
EOF
    git add main.c
    git commit -m "Sensei inicializa variables" --quiet

    echo -e "${GREEN}¡Escenario preparado!${NC}\n"
    echo -e "Misión:"
    echo -e "1. Tu 'compañero' ha dejado cambios en la rama ${GREEN}compañero-rama${NC}."
    echo -e "2. Tú tienes cambios distintos en la misma línea en tu rama (${GREEN}main${NC})."
    echo -e "3. Intenta fusionar la rama de tu compañero en la tuya."
    echo -e "4. ¡Conflicto! Ábrelo en tu editor, resuélvelo manualmente y completa la fusión.\n"
    
    echo -e "Cuando resuelvas el conflicto, vuelve a ejecutar: ${BLUE}./git-gud${NC}"
    echo "2_PENDING" > "$STATE_FILE"
}

setup_lvl3() {
    clear
    echo -e "${YELLOW}>> NIVEL 3: LA URGENCIA (GIT STASH) <<${NC}\n"
    echo "Preparando el escenario final..."
    
    echo -e "NAME = push_swap\nCC = gcc\nCFLAGS = -Wall -Wextra -Werror\n" > Makefile
    git add Makefile
    git commit -m "Añadido Makefile base" --quiet
    echo -e "all: \$(NAME)\n" >> Makefile

    echo -e "${GREEN}¡Escenario preparado!${NC}\n"
    echo -e "Situación:"
    echo -e "Estás a medias modificando el ${GREEN}Makefile${NC}."
    echo -e "¡De repente avisan de un bug URGENTE en ${GREEN}utils.c${NC} que hay que arreglar!\n"
    
    echo -e "Misión:"
    echo -e "1. Guarda tu trabajo del Makefile sin hacer commit (escóndelo en el 'cajón' temporal)."
    echo -e "2. Añade al final de ${GREEN}utils.c${NC} lo siguiente: ${YELLOW}// Hotfix urgente aplicado${NC}"
    echo -e "3. Registra ese hotfix con un commit."
    echo -e "4. Saca tu trabajo del Makefile del cajón temporal para seguir por donde ibas.\n"
    
    echo -e "Cuando lo tengas, ejecuta por última vez: ${BLUE}./git-gud${NC}"
    echo "3_PENDING" > "$STATE_FILE"
}

# ==========================================
# FUNCIONES DE EVALUACIÓN DE NIVELES (CHECK)
# ==========================================

check_lvl1() {
    echo -e "${YELLOW}Evaluando Nivel 1...${NC}"
    sleep 1
    if ! git show-ref --verify --quiet refs/heads/fix-norminette; then
        echo -e "${RED}[KO]${NC} La rama 'fix-norminette' no existe."
        exit 1
    fi
    DIFF=$(git log main..fix-norminette --oneline)
    if [ -z "$DIFF" ]; then
        echo -e "${RED}[KO]${NC} No hay commits nuevos en la rama 'fix-norminette'."
        exit 1
    fi
    
    echo -e "\n${GREEN}========================================${NC}"
    echo -e "${GREEN}¡NIVEL 1 SUPERADO!${NC}"
    echo -e "${GREEN}========================================${NC}"
    echo -e "Bandera: ${YELLOW}FLAG{m4st3r_0f_br4nch3s}${NC}\n"
    
    echo -e "Presiona INTRO para cargar el siguiente nivel..."
    read -r
    setup_lvl2
}

check_lvl2() {
    echo -e "${YELLOW}Evaluando Nivel 2...${NC}"
    sleep 1
    if git ls-files -u | grep -q "main.c"; then
        echo -e "${RED}[KO]${NC} Aún tienes conflictos sin resolver en 'main.c'."
        exit 1
    fi
    if grep -qE "<<<<<<<|=======|>>>>>>>" main.c 2>/dev/null; then
        echo -e "${RED}[KO]${NC} Te has dejado marcas de conflicto (<<<< o ====) escritas en main.c."
        exit 1
    fi
    if ! git branch --merged main | grep -q "compañero-rama"; then
         echo -e "${RED}[KO]${NC} La rama 'compañero-rama' no está fusionada en 'main'."
         exit 1
    fi
    
    echo -e "\n${GREEN}========================================${NC}"
    echo -e "${GREEN}¡NIVEL 2 SUPERADO!${NC}"
    echo -e "${GREEN}========================================${NC}"
    echo -e "Bandera: ${YELLOW}FLAG{c0nfl1ct_k1ll3r_9000}${NC}\n"
    
    echo -e "Presiona INTRO para tu misión final..."
    read -r
    setup_lvl3
}

check_lvl3() {
    echo -e "${YELLOW}Evaluando Nivel 3...${NC}"
    sleep 1
    if ! git log -1 --stat | grep -q "utils.c"; then
        echo -e "${RED}[KO]${NC} No se detecta tu último commit modificando 'utils.c'."
        exit 1
    fi
    if ! git status --porcelain | grep -q " M Makefile"; then
        echo -e "${RED}[KO]${NC} El 'Makefile' no está modificado en tu área de trabajo."
        exit 1
    fi
    
    echo -e "\n${GREEN}========================================${NC}"
    echo -e "${GREEN}¡NIVEL 3 SUPERADO! ¡CTF COMPLETADO!${NC}"
    echo -e "${GREEN}========================================${NC}"
    echo -e "Bandera final: ${YELLOW}FLAG{g1t_m4st3r_unl0ck3d}${NC}\n"
    echo -e "¡Enhorabuena! Ya estás listo para enfrentarte a push_swap en equipo.\n"
    echo "COMPLETED" > "$STATE_FILE"
}

# ==========================================
# FLUJO DEL JUEGO
# ==========================================
case $STATE in
    "0_START")
        setup_lvl1
        ;;
    "1_PENDING")
        check_lvl1
        ;;
    "2_PENDING")
        check_lvl2
        ;;
    "3_PENDING")
        check_lvl3
        ;;
    "COMPLETED")
        echo -e "${GREEN}¡Ya has completado el CTF! Eres un maestro de Git.${NC}"
        echo -e "Si quieres reiniciar el juego, borra esta carpeta y vuelve a clonar el repositorio."
        ;;
esac